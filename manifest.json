{
  "manifest_version": 3,
  "name": "Python Docs Beautifier - Material Theme",
  "version": "1.0.0",
  "description": "A premium theme for Python's official documentation matching the gorgeous MkDocs Material design system.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://docs.python.org/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Python Docs Material Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.python.org/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
